# 复制本文件为 .env 后按需修改

# ===== 引擎选择 =====
# deepgram = 云端流式(准确/低延迟, 需要 API Key)
# local    = 本地离线 faster-whisper(无需 Key/联网, 建议有 NVIDIA 显卡)
TRANSCRIBER_ENGINE=deepgram

# ===== 方案一: 云端 Deepgram =====
# 申请: https://console.deepgram.com/  ->  API Keys  ->  Create a New API Key
DEEPGRAM_API_KEY=

# 识别语言: en=英文(对口音友好) / multi=中英混合 / zh=中文
# 口音偏重时可在 en 与 multi 之间实测哪种更准
DG_LANGUAGE=en

# 关键词提示(提升专有名词/术语/人名准确度, 口音重时尤其有用)
# 逗号分隔, 例如: KEYTERMS=Deepgram,Kubernetes,OKR,Toronto
KEYTERMS=

# 说话人分离: true=区分不同说话人并标注"说话人1/2..." (会自动按说话人换行)
DG_DIARIZE=true
# 长语音断句: 静默间隙超过该毫秒数即断句(最小 1000)
DG_UTTERANCE_END_MS=1000

# ===== 问 AI (可选, 支持多家, 配哪家就能用哪家) =====
# 默认服务商: openai / deepseek / gemini
LLM_PROVIDER=openai

# OpenAI (ChatGPT)  申请: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek  申请: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini  申请: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (免费/极快, 跑 Llama 等)  申请: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ===== 方案二: 本地 faster-whisper(可选) =====
# 模型: tiny/base/small/medium/large-v3 (越大越准越慢)
WHISPER_MODEL=small
# 设备: auto/cuda/cpu ; 计算精度: auto/int8/float16
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
# 语言: 留空=自动(中英); 或固定 zh / en
WHISPER_LANGUAGE=
